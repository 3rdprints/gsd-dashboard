{
  "identifier": "default",
  "description": "Release-strict default capability for the main dashboard window, including list_global_sessions, get_global_chart_data, get_portfolio_heatmap, and project detail commands.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-get-portfolio",
    "allow-get-portfolio-heatmap",
    "allow-get-global-chart-data",
    "allow-get-project",
    "allow-get-project-chart-data",
    "allow-get-project-milestones",
    "allow-get-project-phase-panel",
    "allow-get-boot-status",
    "allow-get-settings",
    "allow-get-watcher-status",
    "allow-clear-session-index",
    "allow-index-sessions",
    "allow-list-global-sessions",
    "allow-list-project-sessions",
    "allow-rebuild-cache",
    "allow-scan-projects",
    "allow-save-settings",
    "clipboard-manager:allow-write-text",
    "opener:allow-reveal-item-in-dir",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "vscode://file/*" }]
    }
  ]
}

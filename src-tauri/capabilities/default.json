{
  "identifier": "default",
  "description": "Release-strict default capability for the main dashboard window, including scan_projects, get_project_milestones, get_project_phase_panel, list_project_sessions, and get_project_chart_data.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-get-portfolio",
    "allow-get-project",
    "allow-get-project-chart-data",
    "allow-get-project-milestones",
    "allow-get-project-phase-panel",
    "allow-get-boot-status",
    "allow-get-settings",
    "allow-index-sessions",
    "allow-list-project-sessions",
    "allow-rebuild-cache",
    "allow-scan-projects",
    "allow-save-settings",
    "clipboard-manager:allow-write-text",
    "opener:allow-reveal-item-in-dir",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "vscode://file/*" }]
    }
  ]
}

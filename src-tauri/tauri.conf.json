{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GSD Dashboard",
  "version": "0.1.3",
  "identifier": "com.smacdonald.gsd-dashboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "title": "GSD Dashboard",
        "label": "main",
        "width": 1100,
        "height": 760,
        "minWidth": 800,
        "minHeight": 560,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlEMDlGREU3RENCQzQ3QjQKUldTMFI3emM1LzBKblNKNFcyTktBL2xkeFhnb3UvRzhrVXlLZHN0RXFieFc4SkEyazVsRTI4YWkK",
      "endpoints": [
        "https://3rdprints.github.io/gsd-dashboard/updates/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

{
  "name": "gsd-dashboard",
  "version": "0.1.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host localhost --port 1420 --strictPort",
    "build": "tsc && vite build",
    "test": "vitest run src && node --test scripts/release/*.test.mjs",
    "docs:check": "node scripts/quality/check-doc-comments.mjs --threshold 85",
    "tauri": "tauri",
    "release:verify-workflow": "node scripts/release/verify-release-workflow.mjs",
    "release:verify-tauri-config": "node scripts/release/verify-tauri-config.mjs",
    "release:verify-manifest": "node scripts/release/verify-updater-manifest.mjs",
    "release:verify-pages": "node scripts/release/verify-pages-site.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-query": "5.101.2",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "2.3.2",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.9.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.7",
    "react-calendar-heatmap": "^1.10.0",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.5",
    "@types/react": "19.2.17",
    "@types/react-calendar-heatmap": "^1.9.0",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "stylelint": "^17.9.1",
    "stylelint-scss": "^7.0.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
